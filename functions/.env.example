# Firebase Functions environment variables (for local emulator use only).
# For production, set these via:
#   firebase functions:config:set email.sendgrid_key="SG.xxxx" email.recipient="staff@lubanrestaurant.com" email.sender="noreply@lubanrestaurant.com"

SENDGRID_API_KEY=SG.replace_with_your_sendgrid_api_key
EMAIL_RECIPIENT=staff@lubanrestaurant.com
EMAIL_SENDER=noreply@lubanrestaurant.com
