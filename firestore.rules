rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin.
    // Checks custom claim (recommended), hardcoded bootstrap email, or
    // membership in the Firestore `admins` collection (managed via Admin tab).
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.admin == true || 
              request.auth.token.email == 'admin@luban.com' ||
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // admins collection – stores emails of users with admin privileges
    match /admins/{adminEmail} {
      // Only existing admins can read or manage the admin list
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // menuItems collection rules (legacy – kept for existing data)
    match /menuItems/{menuItem} {
      // Anyone can read menuItems
      allow read: if true;
      
      // Only authenticated admin can write (create, update, delete) to menuItems
      allow write: if isAdmin();
    }

    // dishAvailability collection – tracks which hardcoded dishes are hidden
    match /dishAvailability/{dishId} {
      // Anyone can read (main site needs to filter hidden dishes)
      allow read: if true;
      
      // Only admins can toggle dish visibility
      allow write: if isAdmin();
    }

    // menuPrices collection – stores admin-overridden prices for hardcoded dishes
    match /menuPrices/{dishId} {
      // Anyone can read (main site and menu page need to display current prices)
      allow read: if true;
      
      // Only admins can update prices
      allow write: if isAdmin();
    }

    // menuImages collection – stores admin-overridden images for hardcoded dishes
    match /menuImages/{dishId} {
      // Anyone can read (main site needs to display current images)
      allow read: if true;

      // Only admins can set or remove image overrides
      allow write: if isAdmin();
    }
    
    // orders collection rules
    match /orders/{orderId} {
      // Admins can read all orders; customers can read their own
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      
      // Authenticated users can place orders (userId must match their own UID)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Admins can update/delete any order; customers can update (cancel) their own
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    // reservations collection rules
    match /reservations/{reservation} {
      // Only admins can read reservations
      allow read: if isAdmin();
      
      // Authenticated users can create new reservations
      allow create: if isAuthenticated();
      
      // Only admins can update or delete reservations
      allow update, delete: if isAdmin();
    }

    // contact_messages collection – submitted via the Contact Us page
    match /contact_messages/{messageId} {
      // Anyone can submit a contact message (no auth required)
      allow create: if true;

      // Only admins can read or update (e.g. mark as read) messages
      allow read, update: if isAdmin();

      // Only admins can delete messages
      allow delete: if isAdmin();
    }

    // teamProfiles collection – staff profiles submitted via the profile form
    match /teamProfiles/{profileId} {
      // Anyone can read approved profiles (displayed publicly on the team page)
      allow read: if resource.data.status == 'approved' || isAdmin();

      // Only admins can create profiles (form is admin-gated)
      allow create: if isAdmin() &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.firstName is string &&
                       request.resource.data.firstName.size() > 0 &&
                       request.resource.data.lastName is string &&
                       request.resource.data.lastName.size() > 0 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.size() > 0;

      // Only admins can update (e.g. approve/reject) or delete profiles
      allow update, delete: if isAdmin();
    }
  }
}
