rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin.
    // Checks custom claim (recommended), hardcoded bootstrap email, or
    // membership in the Firestore `admins` collection (managed via Admin tab).
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.admin == true || 
              request.auth.token.email == 'admin@luban.com' ||
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // admins collection – stores emails of users with admin privileges
    match /admins/{adminEmail} {
      // Allow an authenticated user to read their own admin doc (so client-side checks work),
      // or allow existing admins to read the full list.
      allow read: if isAdmin() || (isAuthenticated() && adminEmail == request.auth.token.email);
      // Only admins can write to the admins list
      allow write: if isAdmin();
    }
    
    // menuItems collection rules (legacy – kept for existing data)
    match /menuItems/{menuItem} {
      // Anyone can read menuItems
      allow read: if true;
      
      // Only authenticated admin can write (create, update, delete) to menuItems
      allow write: if isAdmin();
    }

    // dishAvailability collection – tracks which hardcoded dishes are hidden
    match /dishAvailability/{dishId} {
      // Anyone can read (main site needs to filter hidden dishes)
      allow read: if true;
      
      // Only admins can toggle dish visibility
      allow write: if isAdmin();
    }

    // menuPrices collection – stores admin-overridden prices for hardcoded dishes
    match /menuPrices/{dishId} {
      // Anyone can read (main site and menu page need to display current prices)
      allow read: if true;
      
      // Only admins can update prices
      allow write: if isAdmin();
    }

    // menuImages collection – stores admin-overridden images for hardcoded dishes
    match /menuImages/{dishId} {
      // Anyone can read (main site needs to display current images)
      allow read: if true;

      // Only admins can set or remove image overrides
      allow write: if isAdmin();
    }
    
    // priceOverrides collection – stores temporary price overrides for dishes
    match /priceOverrides/{docId} {
      // Anyone can read (main site and menu page need to show updated prices)
      allow read: if true;

      // Only admins can create or update price overrides
      allow write: if isAdmin();
    }
    
    // orders collection rules
    match /orders/{orderId} {
      // Admins can read all orders; customers can read their own
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);

      // Authenticated users can place orders (userId must match their own UID)
      // Require that the placing user has a phone number recorded in their `/users/{uid}` document
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone is string &&
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone.size() > 0);
      
      // Admins can update/delete any order.
      // Customers can update (cancel) their own orders; they may delete their own orders
      // only when the order is finished (completed) or cancelled to prevent accidental removal.
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow delete: if isAdmin() || (
        isAuthenticated() &&
        request.auth.uid == resource.data.userId &&
        (resource.data.status == 'completed' || resource.data.status == 'cancelled')
      );
    }

    // reservations collection rules
    match /reservations/{reservation} {
      // Only admins can read reservations
      allow read: if isAdmin();
      
      // Authenticated users can create new reservations.
      // Allow unauthenticated users to create reservations only when
      // the request includes the required fields (basic validation)
      allow create: if isAuthenticated() || (
        request.resource.data.name is string && request.resource.data.name.size() > 0 &&
        request.resource.data.phone is string && request.resource.data.phone.size() > 0 &&
        request.resource.data.date is string && request.resource.data.date.size() > 0 &&
        request.resource.data.time is string && request.resource.data.time.size() > 0 &&
        request.resource.data.guests is string && request.resource.data.guests.size() > 0 &&
        request.resource.data.status == 'pending'
      );
      
      // Only admins can update or delete reservations
      allow update, delete: if isAdmin();
    }

    // contact_messages collection – submitted via the Contact Us page
    match /contact_messages/{messageId} {
      // Anyone can submit a contact message (no auth required)
      allow create: if true;

      // Only admins can read or update (e.g. mark as read) messages
      allow read, update: if isAdmin();

      // Only admins can delete messages
      allow delete: if isAdmin();
    }

    // chatbotKnowledge collection - public, admin-managed facts for the site chatbot
    match /chatbotKnowledge/{knowledgeId} {
      // Anyone can read these documents because they are included in public chatbot answers
      allow read: if true;

      // Only admins can create or update chatbot knowledge
      allow write: if isAdmin();
    }

    // users collection – stores customer profiles (name, phone)
    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);

      // Enforce that newly created user profiles include a properly formatted Ghana phone number
      // Phone must be +233 followed by exactly 9 digits (e.g., +233501234567)
      allow create: if isAuthenticated() && request.auth.uid == userId &&
                      request.resource.data.phone is string && 
                      request.resource.data.phone.matches('^\\+233[0-9]{9}$');

      // Allow updates to the user's own profile (including adding/updating phone)
      allow update: if isAuthenticated() && request.auth.uid == userId &&
                      request.resource.data.phone is string &&
                      request.resource.data.phone.matches('^\\+233[0-9]{9}$');

      // Allow delete only for the user themself or admins
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // teamProfiles collection – staff profiles submitted via the profile form
    match /teamProfiles/{profileId} {
      // Anyone can read approved profiles (displayed publicly on the team page)
      allow read: if resource.data.status == 'approved' || isAdmin();

      // Only admins can create profiles (form is admin-gated)
      allow create: if isAdmin() &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.firstName is string &&
                       request.resource.data.firstName.size() > 0 &&
                       request.resource.data.lastName is string &&
                       request.resource.data.lastName.size() > 0 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.size() > 0;

      // Only admins can update (e.g. approve/reject) or delete profiles
      allow update, delete: if isAdmin();
    }
  }
}
