{
  "hosting": {
    "site": "luban-workshop-restaurant",
    "public": ".",
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "us-central1"
        }
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase",
      ".firebase/**",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      "**/.*",
      "**/.*/**",
      "node_modules",
      "node_modules/**",
      "**/node_modules/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.log",
      "**/*.log",
      "*.local",
      "**/*.local",
      "*.map",
      "**/*.map",
      "*.tmp",
      "**/*.tmp",
      "*.bak",
      "**/*.bak",
      ".env",
      ".env*",
      ".env.*",
      "**/.env",
      "**/.env.*",
      ".cache",
      ".cache/**",
      ".vscode",
      ".vscode/**",
      ".idea",
      ".idea/**",
      ".vercel",
      ".vercel/**",
      ".netlify",
      ".netlify/**",
      "functions/**",
      "luabn/**",
      "src/**",
      "tools/**",
      "docs/**",
      "tmp/**",
      "coverage/**",
      "dist/**",
      "build/**",
      "package.json",
      "package-lock.json",
      "tailwind.config.js",
      "firestore.rules",
      "firestore.rules.production",
      "firestore.indexes.json",
      "storage.rules",
      "**/*.md",
      "PRODUCTION_CHECKLIST.md",
      "restcon.webp"
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "source": "functions"
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
