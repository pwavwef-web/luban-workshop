{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      ".env*",
      "functions/**",
      "luabn/**",
      "src/**",
      "README.md",
      "PRODUCTION_CHECKLIST.md",
      "WEBSITE_READINESS_REPORT.md",
      "FIRESTORE_RULES_README.md",
      "restcon.png",
      "restcon.webp"
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "source": "functions"
    },
    {
      "source": "luabn",
      "codebase": "luabn",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
