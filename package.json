  "scripts": {
    "build": "npm run build:css && npm run build:js && npm run build:admin",
    "build:css": "tailwindcss -i src/tailwind.css -o tailwind.css --minify",
    "build:images": "powershell -ExecutionPolicy Bypass -File tools/generate-responsive-images.ps1",
    "build:js": "node tools/build-bundles.js site",
    "build:admin": "node tools/build-bundles.js admin",
    "check": "npm run lint && npm run check:launch && npm run check:functions",
    "check:functions": "node --check functions/index.js && node --check functions/secure-api.js",
    "check:launch": "node tools/check-launch-readiness.js",
    "format": "prettier --write package.json README.md eslint.config.js playwright.config.js tools/build-bundles.js tools/serve-static.js \"tests/**/*.js\"",
    "format:check": "prettier --check package.json README.md eslint.config.js playwright.config.js tools/build-bundles.js tools/serve-static.js \"tests/**/*.js\"",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "watch:css": "tailwindcss -i src/tailwind.css -o tailwind.css --watch"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "html2canvas": "^1.4.1",
    "lucide": "^1.16.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.23.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19"
  }
}
